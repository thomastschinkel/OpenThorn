# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Netlify deploy function — Personal Access Token from app.netlify.com/user/applications
# Set this in your Netlify environment variables (not in this file)
NETLIFY_TOKEN=your-netlify-pat-here

# Sentry — get DSN from sentry.io > Your Project > Settings > Client Keys
VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# PostHog — get key from posthog.com > Your Project > Settings
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com
