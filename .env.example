# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Netlify deploy function — Personal Access Token from app.netlify.com/user/applications
# Set this in your Netlify environment variables (not in this file)
NETLIFY_TOKEN=your-netlify-pat-here
