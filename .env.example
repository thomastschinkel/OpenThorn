# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Server-side only (set in the Vercel project env, NOT exposed to the browser) ---

# Supabase credentials used by the /api functions to verify the caller's JWT.
# These can mirror the VITE_ values above.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Netlify Personal Access Token used to deploy user-generated sites.
# Get it from app.netlify.com/user/applications
NETLIFY_TOKEN=your-netlify-pat-here

# Secret used to encrypt stored provider API keys at rest (AES-256-GCM).
# Generate a long random value, e.g. `openssl rand -base64 48`.
# If unset, the app falls back to weaker client-side key encryption.
KEY_ENCRYPTION_SECRET=your-long-random-secret-here
